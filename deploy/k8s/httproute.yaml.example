---
# Example: expose holyclaude via an Istio/Gateway-API parent gateway that
# is fronted by a Cloudflare Tunnel. Names below match the homelab setup
# (cc.freitas.app, main-gateway in istio-system) — adapt for your cluster.
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: holyclaude
  namespace: holyclaude
spec:
  parentRefs:
    - group: gateway.networking.k8s.io
      kind: Gateway
      name: main-gateway
      namespace: istio-system
      sectionName: https
    - group: gateway.networking.k8s.io
      kind: Gateway
      name: main-gateway
      namespace: istio-system
      sectionName: http
  hostnames:
    - cc.freitas.app
  rules:
    - matches:
        - path:
            type: PathPrefix
            value: /
      backendRefs:
        - group: ""
          kind: Service
          name: holyclaude
          namespace: holyclaude
          port: 3001
          weight: 1
